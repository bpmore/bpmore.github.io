          "_name": "msg-box8",
          "_anchor": "msg-box8-a",
          "_params": {
            "paddingTop": 3,
            "paddingBottom": 3,
            "parallax": true,
            "bgImageRadio": true,
            "bgImage": "@PROJECT_PATH@/assets/images/littlerock-copy-2000x1333.jpg",
            "bgColor": "#F2F2F2",
            "bgColorRadio": false,
